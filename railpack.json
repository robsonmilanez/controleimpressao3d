{
  "$schema": "https://schema.railpack.com",
  "provider": "python",
  "steps": {
    "install": {
      "commands": [
        "...",
        "python -m playwright install chromium"
      ]
    }
  },
  "deploy": {
    "aptPackages": [
      "libasound2t64",
      "libatk-bridge2.0-0",
      "libatk1.0-0",
      "libatspi2.0-0",
      "libcairo2",
      "libcups2",
      "libdbus-1-3",
      "libdrm2",
      "libgbm1",
      "libnspr4",
      "libnss3",
      "libpango-1.0-0",
      "libx11-6",
      "libxcb1",
      "libxcomposite1",
      "libxdamage1",
      "libxext6",
      "libxfixes3",
      "libxkbcommon0",
      "libxrandr2",
      "fonts-liberation"
    ]
  }
}
